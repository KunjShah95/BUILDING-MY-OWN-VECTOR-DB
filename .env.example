# Copy to .env and edit for local/dev or deploy
DATABASE_URL=postgresql://vector_user:vector_password@localhost:5432/vector_db

APP_NAME=Vector Database API
APP_VERSION=1.0.0
DEBUG=false

DEFAULT_M=32
DEFAULT_M0=64
DEFAULT_EF_CONSTRUCTION=300
DEFAULT_EF_SEARCH=50
DEFAULT_DISTANCE_METRIC=cosine
DEFAULT_N_CLUSTERS=100
DEFAULT_N_PROBES=10

API_KEY=your-api-key-here
ALLOWED_HOSTS=*

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_TIME=60

PORT=8000
UVICORN_WORKERS=4

# Storage backend: local | s3 | azure
STORAGE_PROVIDER=local
# S3 (for provider=s3)
S3_BUCKET=vector-db-storage
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Azure Blob (for provider=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER=vector-db-storage
# Redis caching
REDIS_URL=
